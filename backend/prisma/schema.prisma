datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

// ==========================================
// ENUMS
// ==========================================

enum Role {
  DOCTOR
  PHARMACIST
  LABORATORIST
  NURSE
  RECEPTIONIST
  ADMIN
}

// The core state machine for the queues
enum VisitStatus {
  WAITING_TRIAGE        // In Reception waiting for Nurse
  WAITING_CONSULTATION  // Vitals taken, waiting for Doctor
  IN_CONSULTATION       // Currently with Doctor
  AT_LAB                // Sent to Lab
  WAITING_LAB_REVIEW    // Lab done, waiting for Doctor to review results
  AT_PHARMACY           // Sent to Pharmacy
  DISCHARGED            // Visit complete
  CANCELLED             // Patient left or cancelled
}

enum UrgencyLevel {
  ROUTINE
  URGENT
  EMERGENCY
}

enum RequestStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum WardStatus {
  ACTIVE
  INACTIVE
}

enum BedStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

enum DripStandStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
}

enum AllocationStatus {
  ACTIVE
  ENDED
}

// ==========================================
// MODELS
// ==========================================

model Staff {
  id           Int      @id @default(autoincrement())
  staffId      String   @unique @map("staff_id")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  email        String   @unique
  passwordHash String   @map("password_hash") // Added here for authentication
  role         Role
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  visitsHandled  Visit[]          @relation("DoctorVisits")
  vitalsRecorded Vitals[]         @relation("NurseVitals")
  clinicalNotes  ClinicalNote[]
  labRequests    LabRequest[]     @relation("OrderingDoctor")
  labFulfilled   LabRequest[]     @relation("FulfillingLabTech")
  prescriptions  Prescription[]   @relation("PrescribingDoctor")
  prescDispensed Prescription[]   @relation("DispensingPharmacist")
  nurseAssignments NurseAssignment[] @relation("AssignedNurse")

  @@map("staff")
}

model Patient {
  id            Int      @id @default(autoincrement())
  matricNumber  String   @unique @map("matric_number") // Primary identifier for the ecosystem
  firstName     String   @map("first_name")
  lastName      String   @map("last_name")
  dateOfBirth   DateTime @map("date_of_birth")
  gender        String
  contactNumber String?  @map("contact_number")
  department    String?  
  level         Int?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  visits          Visit[]
  vitalsHistory   Vitals[]
  clinicalNotes   ClinicalNote[]
  beds            Bed[]
  dripStands      DripStand[]
  nurseAssignments NurseAssignment[]
  allocations     Allocation[]

  @@map("patients")
}

// The Visit model is the heart of the queue system. 
// Every time a student walks in, a new Visit is created.
model Visit {
  id            Int          @id @default(autoincrement())
  visitId       String       @unique @map("visit_id")
  patientId     Int          @map("patient_id")
  doctorId      Int?         @map("doctor_id") // Assigned when doctor accepts patient
  
  status        VisitStatus  @default(WAITING_TRIAGE)
  urgency       UrgencyLevel @default(ROUTINE) // Set by nurse
  
  checkInTime   DateTime     @default(now()) @map("check_in_time")
  dischargeTime DateTime?    @map("discharge_time")

  // Relations
  patient          Patient           @relation(fields: [patientId], references: [id])
  doctor           Staff?            @relation("DoctorVisits", fields: [doctorId], references: [id])
  vitals           Vitals?           // One-to-one for this specific visit
  notes            ClinicalNote[]
  labRequests      LabRequest[]
  prescriptions    Prescription[]
  nurseAssignments NurseAssignment[]
  allocations      Allocation[]

  @@map("visits")
}

model Vitals {
  id          Int      @id @default(autoincrement())
  visitId     Int      @unique @map("visit_id")
  patientId   Int      @map("patient_id")
  recordedBy  Int      @map("recorded_by") // The Nurse
  
  temperature Float?
  bloodPress  String?  @map("blood_pressure") // e.g., "120/80"
  pulseRate   Int?     @map("pulse_rate")
  weight      Float?
  
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  visit       Visit   @relation(fields: [visitId], references: [id])
  patient     Patient @relation(fields: [patientId], references: [id])
  nurse       Staff   @relation("NurseVitals", fields: [recordedBy], references: [id])

  @@map("vitals")
}

// Dedicated space for Doctor's history and the AI integration opening
model ClinicalNote {
  id          Int      @id @default(autoincrement())
  visitId     Int      @map("visit_id")
  patientId   Int      @map("patient_id")
  doctorId    Int      @map("doctor_id")
  
  symptoms    String   @db.Text
  diagnosis   String?  @db.Text
  aiSummary   String?  @db.Text @map("ai_summary") // Perfect target for rule-based extraction or summaries
  
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  visit       Visit   @relation(fields: [visitId], references: [id])
  patient     Patient @relation(fields: [patientId], references: [id])
  doctor      Staff   @relation(fields: [doctorId], references: [id])

  @@map("clinical_notes")
}

model LabRequest {
  id              Int           @id @default(autoincrement())
  visitId         Int           @map("visit_id")
  orderingDocId   Int           @map("ordering_doc_id")
  labTechId       Int?          @map("lab_tech_id") // Assigned when lab picks it up
  
  testType        String        @map("test_type")
  status          RequestStatus @default(PENDING)
  results         String?       @db.Text // Text results
  resultFileUrl   String?       @map("result_file_url") // Uploaded PDF/Images
  
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  // Relations
  visit           Visit @relation(fields: [visitId], references: [id])
  orderingDoctor  Staff @relation("OrderingDoctor", fields: [orderingDocId], references: [id])
  labTech         Staff? @relation("FulfillingLabTech", fields: [labTechId], references: [id])

  @@map("lab_requests")
}

model Prescription {
  id              Int           @id @default(autoincrement())
  visitId         Int           @map("visit_id")
  prescribingDoc  Int           @map("prescribing_doc")
  pharmacistId    Int?          @map("pharmacist_id")
  
  medicationName  String        @map("medication_name")
  dosage          String
  instructions    String
  status          RequestStatus @default(PENDING)
  
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  // Relations
  visit           Visit  @relation(fields: [visitId], references: [id])
  doctor          Staff  @relation("PrescribingDoctor", fields: [prescribingDoc], references: [id])
  pharmacist      Staff? @relation("DispensingPharmacist", fields: [pharmacistId], references: [id])

  @@map("prescriptions")
}

// ==========================================
// WARD MANAGEMENT & RESOURCE ALLOCATION
// ==========================================

model Ward {
  id          Int         @id @default(autoincrement())
  name        String
  code        String      @unique
  floor       Int
  description String?
  status      WardStatus  @default(ACTIVE)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  beds        Bed[]
  dripStands  DripStand[]
  nurseAssignments NurseAssignment[]

  @@map("wards")
}

model Bed {
  id          Int       @id @default(autoincrement())
  bedNumber   String    @map("bed_number")
  wardId      Int       @map("ward_id")
  status      BedStatus @default(AVAILABLE)
  patientId   Int?      @map("patient_id")
  notes       String?
  allocatedAt DateTime? @map("allocated_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  patient Patient? @relation(fields: [patientId], references: [id])
  ward    Ward     @relation(fields: [wardId], references: [id])

  @@map("beds")
}

model DripStand {
  id          Int             @id @default(autoincrement())
  standCode   String          @unique @map("stand_code")
  wardId      Int?            @map("ward_id")
  status      DripStandStatus @default(AVAILABLE)
  patientId   Int?            @map("patient_id")
  allocatedAt DateTime?       @map("allocated_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  patient Patient? @relation(fields: [patientId], references: [id])
  ward    Ward?    @relation(fields: [wardId], references: [id])

  @@map("drip_stands")
}

model NurseAssignment {
  id          Int              @id @default(autoincrement())
  visitId     Int              @map("visit_id")
  patientId   Int              @map("patient_id")
  nurseId     Int              @map("nurse_id")
  wardId      Int?             @map("ward_id")
  notes       String?
  assignedAt  DateTime         @default(now()) @map("assigned_at")
  endedAt     DateTime?        @map("ended_at")
  status      AllocationStatus @default(ACTIVE)
  createdAt   DateTime         @default(now()) @map("created_at")

  visit   Visit  @relation(fields: [visitId], references: [id])
  patient Patient @relation(fields: [patientId], references: [id])
  nurse   Staff  @relation("AssignedNurse", fields: [nurseId], references: [id])
  ward    Ward?  @relation(fields: [wardId], references: [id])

  @@map("nurse_assignments")
}

model Allocation {
  id          Int              @id @default(autoincrement())
  visitId     Int              @map("visit_id")
  patientId   Int              @map("patient_id")
  resourceType String          @map("resource_type")
  resourceId   Int             @map("resource_id")
  notes       String?
  allocatedAt DateTime         @default(now()) @map("allocated_at")
  deallocatedAt DateTime?      @map("deallocated_at")
  status      AllocationStatus @default(ACTIVE)
  createdAt   DateTime         @default(now()) @map("created_at")

  visit   Visit   @relation(fields: [visitId], references: [id])
  patient Patient @relation(fields: [patientId], references: [id])

  @@map("allocations")
}